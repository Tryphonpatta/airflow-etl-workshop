# Airflow needs your host UID so files written from inside the containers
# (logs, generated data) are owned by you and not root.
# On macOS the default 50000 works fine; on Linux run:  echo "AIRFLOW_UID=$(id -u)"
AIRFLOW_UID=50000

# Default login for the Airflow web UI (http://localhost:8080)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Connection string Airflow will use to reach the analytics warehouse.
# The host "warehouse-postgres" is the docker-compose service name.
AIRFLOW_CONN_WAREHOUSE_POSTGRES=postgresql://warehouse:warehouse@warehouse-postgres:5432/sales
